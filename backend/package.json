{
  "name": "message-app-backend",
  "version": "1.0.0",
  "description": "Minimal Node/Express/PostgreSQL message app backend for CI/CD practice",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint .",
    "test": "jest tests/unit.test.js",
    "test:integration": "jest tests/integration.test.js --runInBand",
    "test:report": "JEST_JUNIT_OUTPUT_DIR=reports jest --ci --runInBand --coverage --reporters=default --reporters=jest-junit",
    "build": "docker build -t message-app-backend ."
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.0.0"
  }
}
